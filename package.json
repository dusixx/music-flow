{
  "name": "music-flow",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.{ts,html,css,json}\"",
    "format:fix": "prettier --write --list-different --ignore-unknown \"src/**/*.{ts,html,css,json}\"",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "fix:all": "npm run lint:fix && npm run format:fix && npm run stylelint:fix",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@taiga-ui/cdk": "^5.7.0",
    "@taiga-ui/core": "^5.7.0",
    "@taiga-ui/icons": "^5.7.0",
    "@taiga-ui/kit": "^5.7.0",
    "angular-split": "^20.0.0",
    "fast-average-color": "^9.5.2",
    "firebase": "^12.13.0",
    "modern-normalize": "^3.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "less": "^4.6.4",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
